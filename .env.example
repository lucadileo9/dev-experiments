# Production Environment Variables

# Django
DJANGO_SECRET_KEY=change-this-to-random-secret-key-50-characters-long
DJANGO_SETTINGS_MODULE=django_project.production_settings

# MySQL Database
MYSQL_DATABASE=blog
MYSQL_USER=django
MYSQL_PASSWORD=change-this-strong-password
MYSQL_ROOT_PASSWORD=change-this-root-password

# Docker Image
IMAGE_NAME=registry.gitlab.com/luca_di_leo/cloudedgecomputing:latest


